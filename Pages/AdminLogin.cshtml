@page
@model WeatherApp.Pages.AdminLoginModel
@{
    ViewData["Title"] = "Admin Login";
}

<div class="contact-container">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="contact-content">
                    <h1 class="display-4 text-center mb-4">Admin Login</h1>
                    
                    @if (Model.LoginFailed)
                    {
                        <div class="neon-error">
                            <i class="fas fa-exclamation-triangle"></i> Invalid username or password!
                        </div>
                    }
                    
                    <div class="card shadow-lg">
                        <div class="card-body p-5">
                            <form method="post">
                                <div class="mb-3">
                                    <label asp-for="Username" class="form-label">Username</label>
                                    <input type="text" class="form-control" asp-for="Username" required>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Password" class="form-label">Password</label>
                                    <input type="password" class="form-control" asp-for="Password" required>
                                </div>
                                <div class="text-center">
                                    <button type="submit" class="btn btn-primary btn-lg">
                                        <i class="fas fa-sign-in-alt"></i> Login
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>