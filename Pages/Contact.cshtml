@page
@model WeatherApp.Pages.ContactModel
@{
    ViewData["Title"] = "Contact";
}

<div class="contact-container">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="contact-content">
                    <h1 class="display-4 text-center mb-4">Contact Us</h1>
                    
                    @if (Model.MessageSent)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle"></i> Message Sent Successfully!
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    
                    <div class="card shadow-lg">
                        <div class="card-body p-5">
                            <form method="post">
                                <div class="mb-3">
                                    <label asp-for="Name" class="form-label">Name</label>
                                    <input type="text" class="form-control" asp-for="Name" required>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label">Email</label>
                                    <input type="email" class="form-control" asp-for="Email" required>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Message" class="form-label">Message</label>
                                    <textarea class="form-control" asp-for="Message" rows="5" required></textarea>
                                </div>
                                <div class="text-center">
                                    <button type="submit" class="btn btn-primary btn-lg">
                                        <i class="fas fa-paper-plane"></i> Send Message
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>